  player: {fileID: 2416464619303331492}
  cameraSwitcher: {fileID: 1017677486}
  droneMovement: {fileID: 1899361740}
  droneHUD: {fileID: 1100959762}
  playerTransform: {fileID: 1343162607606214583}
  visionDetector: {fileID: 5695271831210173489}
  droneCameraTransform: {fileID: 606544787}
  playerFOVAngle: 60
  playerFOVDistance: 30
  introEntry: {fileID: 11400000, guid: 37cf526e24f0a0b49a4b1330e4a70568, type: 2}
  moveEntry: {fileID: 11400000, guid: 180d41ea9dbe1c44fbe58c5183a15424, type: 2}
  droneEntry: {fileID: 11400000, guid: d47742e0f494a5a4184b999930379abb, type: 2}
  droneMoveLines:
  - "\xBFNo recuerdas c\xF3mo funcionaba?"
  - No pasa nada.
  - "Te hago un repaso r\xE1pido."
  - Con el joystick izquierdo puedo desplazarme libremente.
  - "Y con el joystick derecho puedo mirar en cualquier direcci\xF3n."
  droneFOVLines:
  - "Si pulsas B una vez, cambiar\xE9 a vista plana."
  - Algunos dicen que ayuda a encontrar caminos ocultos.
  orthoMoveLines:
  - "Mientras est\xE9 en vista plana aparecer\xE1 mi cursor interactivo."
  - Puedes moverlo con el joystick izquierdo.
  orthoAcceptLines:
  - "Y seleccionar una posici\xF3n para desplazarte hasta ella pulsando A."
  orthoExitLines:
  - "Si pulsas X volver\xE9 al modo normal del dron."
  exitDroneLines:
  - Y si vuelves a pulsar X...
  - Regresaremos junto a ti.
  cursorEntry: {fileID: 11400000, guid: 85115ae4b7e5d8b4eb722c1466ad7dda, type: 2}
  cursorHoldEntry: {fileID: 11400000, guid: e56c2fcb3107cf746b58b9ef425ae0a3, type: 2}
  tutorialEndEntry: {fileID: 11400000, guid: a11f3f3d99a43914eacb6379be996703, type: 2}
